   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "hf_login"
   },
   "source": [
    "## 3. (Optional) Log in to Hugging Face\n",
    "\n",
    "The model is publicly accessible, so login is not required.\n",
    "Only needed if you want to access gated models or push results.\n",
    "\n",
    "**Do not hardcode tokens.** Use the Colab ` secrets`  panel instead:\n",
    "1. Click the key icon in the left toolbar\n",
    "2. Add a secret named `HF_TOKEN` with your token value\n",
    "3. Enable notebook access"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "login"
   },
   "outputs": [],
   "source": [
    "from huggingface_hub import login\n",
    "from google.colab import userdata\n",
    "\n",
    "try:\n",
    "    token = userdata.get(\"HF_TOKEN\")\n",
    "    login(token, add_to_git_credential=False)\n",
    "    print(\"Logged in to Hugging Face.\")\n",
    "except Exception:\n",
    "    print(\"No HF_TOKEN secret found. Continuing anonymously (public model only).\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "load"
   },
   "source": [
    "## 4. Load Model and Tokenizer\n",
    "\n",
    "Loading from the OMCHOKSI108 mirror. First download may take a few minutes."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "model_load"
   },
   "outputs": [],
   "source": [
    "from transformers import AutoModelForCausalLM, AutoTokenizer\n",
    "\n",
    "MODEL_NAME = \"OMCHOKSI108/VibeThinker-3B\"\n",
    "\n",
    "print(\"Downloading model... (this may take 2-5 minutes)\")\n",
    "model = AutoModelForCausalLM.from_pretrained(\n",
    "    MODEL_NAME,\n",
    "    low_cpu_mem_usage=True,\n",
    "    torch_dtype=torch.bfloat16,\n",
    "    device_map=\"auto\",\n",
    ")\n",
    "tokenizer = AutoTokenizer.from_pretrained(\n",
    "    MODEL_NAME,\n",
    "    trust_remote_code=True,\n",
    ")\n",
    "print(\"Model loaded successfully.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "helper"
   },
   "source": [
    "## 5. Inference Helper Function\n",
    "\n",
    "Define a reusable function for running inference."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "helper_fn"
   },
   "outputs": [],
   "source": [
    "from transformers import GenerationConfig\n",
    "\n",
    "\n",
    "def vibethinker_infer(prompt, temperature=0.6, max_new_tokens=40960):\n",
    "    messages = [{\"role\": \"user\", \"content\": prompt}]\n",
    "    text = tokenizer.apply_chat_template(\n",
    "        messages, tokenize=False, add_generation_prompt=True\n",
    "    )\n",
    "    inputs = tokenizer([text], return_tensors=\"pt\").to(model.device)\n",
    "\n",
    "    outputs = model.generate(\n",
    "        **inputs,\n",
    "        generation_config=GenerationConfig(\n",
    "            max_new_tokens=max_new_tokens,\n",
    "            do_sample=True,\n",
    "            temperature=temperature,\n",
    "            top_p=0.95,\n",
    "            top_k=None,\n",
    "        ),\n",
    "    )\n",
    "    response = tokenizer.decode(\n",
    "        outputs[0][inputs.input_ids.shape[1]:],\n",
    "        skip_special_tokens=True,\n",
    "    )\n",
    "    return response"
   ]
  },
  {
